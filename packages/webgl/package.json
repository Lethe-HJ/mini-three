{
  "name": "@mini-three/webgl",
  "private": false,
  "version": "1.0.0-test",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && vite build",
    "check": "bash scripts/check.sh",
    "typecheck": "tsc -b tsconfig.build.json",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format:check": "oxfmt src --check",
    "format:fix": "oxfmt src",
    "fix": "bash scripts/fix.sh"
  },
  "dependencies": {
    "@mini-three/types": "workspace:*",
    "@plutotcool/glsl-bundler": "^1.4.1"
  },
  "devDependencies": {
    "vite": "^8.0.0-beta.13",
    "vite-plugin-dts": "^4.5.4"
  }
}
