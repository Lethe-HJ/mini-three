{
  "name": "points-cloud-engine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./src/core/index.ts",
  "types": "./src/core/index.ts",
  "exports": {
    ".": {
      "types": "./src/core/index.ts",
      "import": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "example": "vite --config vite.example.config.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "format:fix": "oxfmt src",
    "format:check": "oxfmt src --check",
    "typecheck": "tsc --noEmit",
    "fix": "sh scripts/fix.sh",
    "check": "sh scripts/check.sh"
  },
  "devDependencies": {
    "@types/stats.js": "^0.17.4",
    "@types/three": "^0.170.0",
    "lit": "^3.3.2",
    "points-cloud-engine": "workspace:*",
    "stats.js": "^0.17.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0-beta.13"
  },
  "dependencies": {
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "three": "^0.170.0"
  }
}
