    "postversion": "bash scripts/postversion.sh",
    "deploy": "bash deploy/deploy.sh"
  },
  "dependencies": {
    "lit": "^3.3.2",
    "stats.js": "^0.17.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/stats.js": "^0.17.4",
    "@types/three": "^0.170.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "turbo": "^2.9.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.0-beta.13"
  },
  "pnpm": {
